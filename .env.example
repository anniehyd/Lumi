# ─── Core ───
NEXTAUTH_URL=http://localhost:3000
# openssl rand -base64 32
NEXTAUTH_SECRET=

# ─── Database ───
DATABASE_URL=postgresql://lumi:lumi@localhost:5432/lumi?schema=public

# ─── Redis (BullMQ) ───
REDIS_URL=redis://localhost:6379

# ─── Google OAuth (Gmail + Calendar) ───
# Create at https://console.cloud.google.com/apis/credentials
# Required scopes:
#   openid email profile
#   https://www.googleapis.com/auth/gmail.readonly
#   https://www.googleapis.com/auth/calendar.events
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Anthropic (Claude) ───
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Gmail push (optional; falls back to polling if unset) ───
# Cloud Pub/Sub topic you own: projects/{project}/topics/{topic}
GMAIL_PUBSUB_TOPIC=
# Shared secret to verify Pub/Sub push requests (any random string)
GMAIL_WEBHOOK_SECRET=

# ─── Runtime ───
NODE_ENV=development
# When true, API falls back to mock data if DB is empty
LUMI_USE_MOCK_FALLBACK=true
